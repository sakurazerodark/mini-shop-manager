{
  "name": "mini-shop-manager",
  "private": true,
  "version": "0.1.0",
  "main": "main/index.js",
  "scripts": {
    "start": "cross-env NODE_ENV=development concurrently \"vite --host\" \"node main/start-backend.js\"",
    "start:electron": "cross-env NODE_ENV=development electron .",
    "dev": "vite --host",
    "build": "vite build",
    "build:electron": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.minishop.manager",
    "productName": "MiniShop",
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "public/app.ico"
    },
    "files": [
      "dist/**/*",
      "main/**/*",
      "package.json"
    ],
    "asar": true,
    "npmRebuild": false,
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "axios": "^1.15.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "sqlite3": "^6.0.1",
    "supertest": "^7.2.2",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^28.2.3",
    "electron-builder": "^24.9.1",
    "vite": "^8.0.4",
    "wait-on": "^9.0.5"
  }
}
